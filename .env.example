# ── FinRecon Copilot — environment template ────────────────────────────
# 1. Copy this file to  .env      (cp .env.example .env)
# 2. Paste your real key in .env  (NEVER commit .env — it's in .gitignore)
# 3. config.py loads these at runtime via python-dotenv

# --- LLM provider selection -------------------------------------------
# Which provider config.py should use: "gemini" | "groq" | "ollama"
LLM_PROVIDER=gemini

# --- Google Gemini (free key, no credit card) -------------------------
# Get one at https://aistudio.google.com/  ->  "Get API key"
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-1.5-flash

# --- Groq (free key, very fast) — optional alternative ----------------
# Get one at https://console.groq.com/  ->  "API Keys"
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.1-8b-instant

# --- Ollama (local, private — no data leaves the machine) -------------
# Install from https://ollama.com/ ; run `ollama pull llama3.1`
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- LLM behaviour ----------------------------------------------------
# temperature 0 = deterministic/repeatable (required for finance)
LLM_TEMPERATURE=0
